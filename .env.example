# Telegram Bot
BOT_TOKEN=tu_token_de_botfather

# Modo de operación: "polling" (local/Docker Compose) o "webhook" (Cloud Run)
MODE=polling

# Webhook (solo necesario en modo webhook / Cloud Run)
# WEBHOOK_URL se obtiene después del primer deploy en Cloud Run
# WEBHOOK_SECRET se genera automáticamente con el script de deploy
WEBHOOK_URL=
WEBHOOK_SECRET=
PORT=8080

# AI Providers (opcionales - cada grupo puede configurar su propia key con /clave <provider> <key>)
# Gemini: https://aistudio.google.com/apikey (FREE tier generoso)
GEMINI_API_KEY=tu_api_key_de_gemini
# xAI/Grok: https://console.x.ai/team/default/api-keys ($25/mes free credits)
XAI_API_KEY=
# OpenAI: https://platform.openai.com/api-keys (de pago)
OPENAI_API_KEY=
# Anthropic/Claude: stub, no implementado aún
ANTHROPIC_API_KEY=

# Modelos por provider (el que se usa por defecto en cada provider)
GEMINI_MODEL=gemini-2.0-flash-lite
GROK_MODEL=grok-4.3
OPENAI_MODEL=gpt-4o-mini

# Cifrado de API keys almacenadas en MongoDB (REQUERIDO, mínimo 32 chars)
# Genera una clave segura con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=cambia-esto-por-una-clave-segura-de-al-menos-32-caracteres

# MongoDB
# Local: mongodb://localhost:27017/panitabot
# Docker Compose: mongodb://mongodb:27017/panitabot
# Atlas: mongodb+srv://usuario:password@cluster.mongodb.net/panitabot
MONGODB_URI=mongodb://mongodb:27017/panitabot

# Defaults
# DEFAULT_MODEL: modelo por defecto para grupos nuevos (gemini|grok|openai|claude)
DEFAULT_MODEL=gemini
DEFAULT_MAX_TOKENS=1024
DEFAULT_SUMMARY_COUNT=50
